# Conexão Postgres (obrigatória)
DATABASE_URL=postgresql://user:password@localhost:5432/modula_clinic

# Porta do servidor HTTP
PORT=5000

# development | production
NODE_ENV=development

# Insights de IA (compatível com a API da OpenAI)
# Fora do Replit use a API oficial da OpenAI com a sua chave:
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-sua-chave-aqui
